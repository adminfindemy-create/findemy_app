EXPO_PUBLIC_API_URL=http://localhost:8080
EXPO_PUBLIC_ENV=development
EXPO_PUBLIC_GOOGLE_MAPS_KEY=
EXPO_PUBLIC_SENTRY_DSN=
# Must equal the backend's GOOGLE_ADMIN_IOS/ANDROID_CLIENT_ID (same OAuth client,
# shared client<->server) so the idToken `aud` matches the admin verifier.
EXPO_PUBLIC_GOOGLE_ADMIN_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ADMIN_ANDROID_CLIENT_ID=
